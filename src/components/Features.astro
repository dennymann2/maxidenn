---
import { siteConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';
import { featuresContent } from '../content/features';

const iconMap: Record<string, string> = {
  shield: 'heroicons:shield-check',
  mobile: 'heroicons:device-phone-mobile',
  phone: 'heroicons:phone-arrow-up-right',
  zap: 'heroicons:bolt',
};
---

<section id="features" class="bg-white px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mb-10 max-w-3xl">
      <h2 class="text-brand-primary mb-4 text-3xl font-bold sm:text-4xl">
        {siteConfig.features.title}
      </h2>
      <p class="text-brand-primary text-lg">
        {siteConfig.features.subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        featuresContent.map((feature) => (
          <div class="border-brand-primary bg-brand-bg border-2 p-6 sm:p-8">
            <div class="border-brand-primary text-brand-accent mb-5 flex h-11 w-11 items-center justify-center rounded-md border bg-white">
              <Icon
                name={iconMap[feature.icon] ?? 'heroicons:star'}
                class="h-5 w-5"
              />
            </div>
            <h3 class="text-brand-primary mb-3 text-xl font-semibold">
              {feature.title}
            </h3>
            <p class="text-brand-primary leading-relaxed">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

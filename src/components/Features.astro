---
import { siteConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';
import { featuresContent } from '../content/features';

const iconMap: Record<string, string> = {
  shield: 'heroicons:shield-check',
  mobile: 'heroicons:device-phone-mobile',
  phone: 'heroicons:phone-arrow-up-right',
  zap: 'heroicons:bolt',
};
---

<section id="features" class="relative bg-white px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="scroll-fade-up mx-auto mb-16 max-w-3xl text-center">
      <h2 class="text-brand-primary mb-4 text-4xl font-bold sm:text-5xl">
        {siteConfig.features.title}
      </h2>
      <p class="text-brand-muted text-xl">
        {siteConfig.features.subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      {
        featuresContent.map((feature, index) => (
          <div
            class={`group ${index % 2 === 0 ? 'scroll-fade-left' : 'scroll-fade-right'} border-brand-surface rounded-xl border-2 bg-brand-bg p-8 stagger-${index + 1}`}
          >
            <div class="bg-brand-primary mb-6 flex h-14 w-14 items-center justify-center rounded-lg text-white">
              <Icon name={iconMap[feature.icon] ?? 'heroicons:star'} class="h-7 w-7" />
            </div>
            <h3 class="text-brand-primary mb-3 text-xl font-semibold">
              {feature.title}
            </h3>
            <p class="text-brand-muted leading-relaxed">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

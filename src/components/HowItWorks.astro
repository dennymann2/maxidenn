---
import { siteConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';
import { howItWorksSteps } from '../content/how-it-works';
---

<section
  id="how-it-works"
  class="border-brand-surface relative border-t-2 bg-brand-surface px-4 py-20 sm:px-6 lg:px-8"
>
  <div class="mx-auto max-w-7xl">
    <div class="scroll-fade-down mx-auto mb-16 max-w-3xl text-center">
      <h2 class="text-brand-primary mb-4 text-4xl font-bold sm:text-5xl">
        {siteConfig.howItWorks.title}
      </h2>
      <p class="text-brand-muted text-xl">
        {siteConfig.howItWorks.subtitle}
      </p>
    </div>

    <div class="flex flex-col gap-4 md:flex-row md:items-stretch">
      {
        howItWorksSteps.map((step, index) => (
          <>
            <div
              class={`scroll-fade-up border-brand-surface flex-1 rounded-xl border-2 bg-white p-8 stagger-${index + 1}`}
            >
              <div class="bg-brand-accent mb-6 flex h-12 w-12 items-center justify-center rounded-full text-xl font-bold text-white">
                {step.number}
              </div>
              <h3 class="text-brand-primary mb-3 text-xl font-semibold">
                {step.title}
              </h3>
              <p class="text-brand-muted leading-relaxed">{step.description}</p>
            </div>

            {index < howItWorksSteps.length - 1 && (
              <div class="hidden items-center justify-center px-2 md:flex">
                <Icon
                  name="heroicons:chevron-right"
                  class="text-brand-secondary h-7 w-7 flex-shrink-0"
                />
              </div>
            )}
          </>
        ))
      }
    </div>
  </div>
</section>

---
import { siteConfig } from '../config.ts';
import { howItWorksSteps } from '../content/how-it-works';
---

<section
  id="how-it-works"
  class="border-brand-primary bg-brand-surface border-t-2 px-4 py-16 sm:px-6 sm:py-20 lg:px-8"
>
  <div class="mx-auto max-w-7xl">
    <div class="mb-10 max-w-3xl">
      <h2 class="text-brand-primary mb-4 text-3xl font-bold sm:text-4xl">
        {siteConfig.howItWorks.title}
      </h2>
      <p class="text-brand-primary text-lg">
        {siteConfig.howItWorks.subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        howItWorksSteps.map((step) => (
          <div class="border-brand-primary border-2 bg-white p-6 sm:p-8">
            <div class="border-brand-primary bg-brand-surface text-brand-primary mb-6 inline-flex border-2 px-3 py-1 text-sm font-bold">
              Schritt {step.number}
            </div>
            <h3 class="text-brand-primary mb-3 text-xl font-semibold">
              {step.title}
            </h3>
            <p class="text-brand-primary leading-relaxed">{step.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

---
import { siteConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';

const iconMap: Record<string, string> = {
  instagram: 'simple-icons:instagram',
  linkedin: 'simple-icons:linkedin',
  twitter: 'simple-icons:x',
  github: 'simple-icons:github',
};
---

<footer class="bg-brand-primary px-4 py-16 text-white sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mb-12 grid grid-cols-1 gap-12 md:grid-cols-3">
      <div class="md:col-span-1">
        <div class="mb-3 text-2xl font-bold">{siteConfig.site.name}</div>
        <p class="mb-4 text-sm leading-relaxed text-white/60">
          {siteConfig.footer.tagline}
        </p>
        <p class="text-sm text-white/40">{siteConfig.site.location}</p>
      </div>

      {
        siteConfig.footer.columns.map((column) => (
          <div>
            <h4 class="mb-4 text-sm font-semibold tracking-wide text-white/80">
              {column.title}
            </h4>
            <ul class="space-y-3 text-sm">
              {column.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-white/50 transition-colors hover:text-white"
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="flex flex-col items-center justify-between border-t border-white/10 pt-8 md:flex-row">
      <p class="mb-4 text-sm text-white/40 md:mb-0">
        &copy; {siteConfig.footer.copyright}
      </p>

      <div class="flex space-x-5">
        {
          siteConfig.footer.social.map((social) => (
            <a
              href={social.href}
              class="text-white/40 transition-colors hover:text-white"
              aria-label={social.name}
            >
              <Icon name={iconMap[social.icon] ?? 'heroicons:link'} class="h-5 w-5" />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>

---
import { siteConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';
---

<section
  id="pricing"
  class="border-brand-primary bg-brand-surface border-t-2 px-4 py-16 sm:px-6 sm:py-20 lg:px-8"
>
  <div class="mx-auto max-w-7xl">
    <div class="mb-10 max-w-3xl">
      <h2 class="text-brand-primary mb-4 text-3xl font-bold sm:text-4xl">
        {siteConfig.pricing.title}
      </h2>
      <p class="text-brand-primary text-lg">
        {siteConfig.pricing.subtitle}
      </p>
    </div>

    <div class="border-brand-primary mb-8 border-2 bg-white p-4">
      <p class="text-brand-primary font-semibold">
        Netto-Einmalpreise ohne Folgekosten. Im Erstgespräch besprechen wir, was
        für Ihren Betrieb passt.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        siteConfig.pricing.plans.map((plan) => (
          <div
            class={`flex h-full flex-col border-2 bg-white p-6 sm:p-8 ${plan.featured ? 'border-brand-primary' : 'border-brand-surface'}`}
          >
            {plan.featured && (
              <div class="border-brand-primary text-brand-primary mb-5 border-b-2 pb-3 text-sm font-bold tracking-wide uppercase">
                {plan.badge}
              </div>
            )}

            <h3 class="text-brand-primary mb-2 text-2xl font-bold">
              {plan.name}
            </h3>
            <div class="mb-6">
              <span class="text-brand-primary text-3xl font-bold">
                {plan.price}
              </span>
              {plan.period && (
                <span class="text-brand-muted ml-1 text-sm">{plan.period}</span>
              )}
            </div>
            <p class="text-brand-primary mb-6 text-sm font-semibold">
              {plan.description}
            </p>
            <ul class="mb-8 grow space-y-3">
              {plan.features.map((feature) => (
                <li class="flex items-start">
                  <Icon
                    name="heroicons:check"
                    class="text-brand-accent mt-0.5 mr-3 h-5 w-5 flex-shrink-0"
                  />
                  <span class="text-brand-primary text-sm">{feature}</span>
                </li>
              ))}
            </ul>
            <a
              href={plan.cta.href}
              class={`block w-full rounded-md border-2 px-6 py-3 text-center font-semibold transition-colors ${plan.featured ? 'border-brand-accent bg-brand-accent hover:bg-brand-accent-hover text-white' : 'border-brand-primary text-brand-primary hover:bg-brand-surface bg-white'}`}
            >
              {plan.cta.text}
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

---
import { siteConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';
---

<section
  id="pricing"
  class="border-brand-surface relative border-t-2 bg-brand-surface px-4 py-20 sm:px-6 lg:px-8"
>
  <div class="mx-auto max-w-7xl">
    <div class="scroll-fade-up mx-auto mb-16 max-w-3xl text-center">
      <h2 class="text-brand-primary mb-4 text-4xl font-bold sm:text-5xl">
        {siteConfig.pricing.title}
      </h2>
      <p class="text-brand-muted text-xl">
        {siteConfig.pricing.subtitle}
      </p>
    </div>

    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-8 md:grid-cols-3">
      {
        siteConfig.pricing.plans.map((plan, index) =>
          plan.featured ? (
            <div class="scroll-fade-up scale-105 transform rounded-xl shadow-2xl">
              <div class="bg-brand-primary rounded-xl p-8">
                <div class="bg-brand-accent mb-4 inline-block rounded-full px-3 py-1 text-xs font-semibold text-white">
                  {plan.badge}
                </div>
                <h3 class="mb-2 text-2xl font-bold text-white">{plan.name}</h3>
                <div class="mb-6">
                  <span class="text-3xl font-bold text-white">{plan.price}</span>
                  {plan.period && (
                    <span class="text-brand-secondary ml-1 text-sm">
                      {plan.period}
                    </span>
                  )}
                </div>
                <p class="mb-6 text-sm text-white/70">{plan.description}</p>
                <ul class="mb-8 space-y-3">
                  {plan.features.map((feature) => (
                    <li class="flex items-start">
                      <Icon
                        name="heroicons:check"
                        class="text-brand-accent mt-0.5 mr-3 h-5 w-5 flex-shrink-0"
                      />
                      <span class="text-sm text-white">{feature}</span>
                    </li>
                  ))}
                </ul>
                <a
                  href={plan.cta.href}
                  class="bg-brand-accent hover:bg-brand-accent-hover block w-full rounded-lg px-6 py-3 text-center font-semibold text-white transition-colors"
                >
                  {plan.cta.text}
                </a>
              </div>
            </div>
          ) : (
            <div
              class={`${index === 0 ? 'scroll-fade-left' : 'scroll-fade-right'} border-brand-surface rounded-xl border-2 bg-white p-8`}
            >
              <h3 class="text-brand-primary mb-2 text-2xl font-bold">
                {plan.name}
              </h3>
              <div class="mb-6">
                <span class="text-brand-primary text-3xl font-bold">
                  {plan.price}
                </span>
                {plan.period && (
                  <span class="text-brand-muted ml-1 text-sm">{plan.period}</span>
                )}
              </div>
              <p class="text-brand-muted mb-6 text-sm">{plan.description}</p>
              <ul class="mb-8 space-y-3">
                {plan.features.map((feature) => (
                  <li class="flex items-start">
                    <Icon
                      name="heroicons:check"
                      class="text-brand-accent mt-0.5 mr-3 h-5 w-5 flex-shrink-0"
                    />
                    <span class="text-brand-muted text-sm">{feature}</span>
                  </li>
                ))}
              </ul>
              <a
                href={plan.cta.href}
                class="border-brand-primary text-brand-primary hover:bg-brand-surface block w-full rounded-lg border-2 bg-white px-6 py-3 text-center font-semibold transition-colors"
              >
                {plan.cta.text}
              </a>
            </div>
          ),
        )
      }
    </div>

    <p class="text-brand-muted mt-10 text-center text-sm">
      Alle Preise sind Netto-Einmalpreise ohne Folgekosten. Im Erstgespräch besprechen wir, was für Ihren Betrieb passt.
    </p>
  </div>
</section>

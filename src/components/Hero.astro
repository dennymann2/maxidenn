---
import { siteConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';

const heroFacts = [
  siteConfig.hero.badges[0],
  siteConfig.trustBar.replyTime,
  siteConfig.hero.badges[1],
];
---

<section
  class="border-brand-primary bg-brand-bg border-b-2 px-4 pt-28 pb-16 sm:px-6 sm:pt-32 sm:pb-20 lg:px-8"
>
  <div
    class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)] lg:items-start"
  >
    <div>
      <h1
        class="text-brand-primary mb-6 max-w-4xl text-4xl leading-tight font-extrabold sm:text-5xl lg:text-6xl"
      >
        {siteConfig.hero.headline}
        <span class="text-brand-accent">{siteConfig.hero.subheadline}</span>
      </h1>

      <p
        class="text-brand-primary mb-8 max-w-3xl text-lg leading-relaxed sm:text-xl"
      >
        {siteConfig.hero.description}
      </p>

      <div class="mb-8 flex flex-col gap-3 sm:flex-row">
        <a
          href={siteConfig.hero.cta.primary.href}
          class="bg-brand-accent hover:bg-brand-accent-hover rounded-md px-7 py-4 text-center font-semibold text-white transition-colors"
        >
          {siteConfig.hero.cta.primary.text}
        </a>
        <a
          href={siteConfig.hero.cta.secondary.href}
          class="border-brand-primary text-brand-primary hover:bg-brand-surface rounded-md border-2 bg-white px-7 py-4 text-center font-semibold transition-colors"
        >
          <Icon name="heroicons:phone" class="mr-2 inline h-5 w-5" />
          {siteConfig.hero.cta.secondary.text}
        </a>
      </div>

      <div class="border-brand-primary grid border-y-2 bg-white sm:grid-cols-3">
        {
          heroFacts.map((fact) => (
            <div class="border-brand-primary/25 text-brand-primary flex items-start gap-2 border-b px-4 py-4 text-sm font-semibold last:border-b-0 sm:border-r sm:border-b-0 sm:last:border-r-0">
              <Icon
                name="heroicons:check-circle"
                class="text-brand-accent h-4 w-4 flex-shrink-0"
              />
              <span>{fact}</span>
            </div>
          ))
        }
      </div>
    </div>

    <aside class="border-brand-primary border-2 bg-white p-6">
      <p
        class="text-brand-primary mb-5 text-sm font-bold tracking-wide uppercase"
      >
        Für lokale Betriebe
      </p>

      <div class="space-y-5">
        <div>
          <p class="text-brand-muted mb-1 text-sm">Angebot</p>
          <p class="text-brand-primary font-semibold">
            Webdesign und Entwicklung für Gastronomie, Handwerk und
            Dienstleister.
          </p>
        </div>

        <div class="border-brand-surface border-t pt-5">
          <p class="text-brand-muted mb-1 text-sm">Bewertung</p>
          <a
            href={siteConfig.trustBar.googleUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-primary hover:text-brand-accent inline-flex items-center gap-2 font-semibold"
          >
            <span>{siteConfig.trustBar.googleRating}</span>
            <span>Google-Bewertung</span>
            <Icon name="heroicons:arrow-top-right-on-square" class="h-4 w-4" />
          </a>
        </div>

        <div class="border-brand-surface border-t pt-5">
          <p class="text-brand-muted mb-1 text-sm">Kontakt</p>
          <p class="text-brand-primary font-semibold">
            Direkt per Telefon, WhatsApp oder kurzem Formular.
          </p>
        </div>
      </div>
    </aside>
  </div>
</section>

---
import { siteConfig } from '../config.ts';
import { faqItems } from '../content/faq';
---

<section id="faq" class="bg-white px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
  <div class="mx-auto max-w-4xl">
    <div class="mb-10">
      <h2 class="text-brand-primary mb-4 text-3xl font-bold sm:text-4xl">
        {siteConfig.faq.title}
      </h2>
      <p class="text-brand-primary text-lg">
        {siteConfig.faq.subtitle}
      </p>
    </div>

    <div class="space-y-3">
      {
        faqItems.map((item) => (
          <details class="border-brand-surface rounded-md border-2 bg-white">
            <summary class="text-brand-primary cursor-pointer px-5 py-4 font-semibold">
              {item.question}
            </summary>
            <div class="text-brand-primary px-5 pb-5 leading-relaxed">
              {item.answer}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

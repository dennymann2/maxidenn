---
import { siteConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';
---

<nav
  class="border-brand-primary bg-brand-bg fixed top-0 z-50 w-full border-b-2"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <div class="flex items-center">
        <a href="/" class="text-brand-primary text-xl font-bold tracking-tight">
          {siteConfig.site.name}
        </a>
      </div>

      <div class="hidden items-center space-x-8 lg:flex">
        {
          siteConfig.navigation.links.map((link) => (
            <a
              href={link.href}
              class="text-brand-primary hover:text-brand-accent text-sm font-medium transition-colors"
            >
              {link.name}
            </a>
          ))
        }

        <div
          class="border-brand-primary/30 text-brand-primary hidden items-center gap-2 border-l pl-5 text-xs font-semibold xl:flex"
        >
          <Icon name="heroicons:clock" class="h-4 w-4" />
          {siteConfig.trustBar.replyTime}
        </div>

        <a
          href={siteConfig.site.phoneHref ?? `tel:${siteConfig.site.phone}`}
          class="text-brand-primary hover:text-brand-accent flex items-center gap-1.5 text-sm font-semibold"
        >
          <Icon name="heroicons:phone" class="h-4 w-4" />
          {siteConfig.site.phone}
        </a>

        <a
          href={siteConfig.navigation.cta.href}
          class="bg-brand-accent hover:bg-brand-accent-hover rounded-md px-5 py-2 text-sm font-semibold text-white transition-colors"
        >
          {siteConfig.navigation.cta.text}
        </a>
      </div>

      <button
        id="mobileMenuButton"
        class="border-brand-primary rounded-md border p-2 lg:hidden"
        aria-controls="mobileMenu"
        aria-expanded="false"
        aria-label="Menü öffnen"
      >
        <Icon name="heroicons:bars-3" class="text-brand-primary h-6 w-6" />
      </button>
    </div>

    <div
      id="mobileMenu"
      class="border-brand-primary hidden border-t py-4 lg:hidden"
      aria-hidden="true"
    >
      <div class="flex flex-col space-y-3">
        {
          siteConfig.navigation.links.map((link) => (
            <a
              href={link.href}
              class="text-brand-primary py-2 text-sm font-medium"
            >
              {link.name}
            </a>
          ))
        }
        <div
          class="text-brand-primary flex items-center gap-2 py-2 text-sm font-semibold"
        >
          <Icon name="heroicons:clock" class="h-4 w-4" />
          {siteConfig.trustBar.replyTime}
        </div>
        <a
          href={siteConfig.site.phoneHref ?? `tel:${siteConfig.site.phone}`}
          class="text-brand-primary flex items-center gap-2 py-2 text-sm font-semibold"
        >
          <Icon name="heroicons:phone" class="h-4 w-4" />
          {siteConfig.site.phone}
        </a>
        <a
          href={siteConfig.navigation.cta.href}
          class="bg-brand-accent rounded-md px-6 py-3 text-center text-sm font-semibold text-white"
        >
          {siteConfig.navigation.cta.text}
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuButton = document.getElementById('mobileMenuButton');
    const mobileMenu = document.getElementById('mobileMenu');

    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener('click', () => {
        const isExpanded =
          mobileMenuButton.getAttribute('aria-expanded') === 'true';
        mobileMenuButton.setAttribute('aria-expanded', String(!isExpanded));
        mobileMenu.setAttribute('aria-hidden', String(isExpanded));
        mobileMenu.classList.toggle('hidden');
      });

      const mobileMenuLinks = mobileMenu.querySelectorAll('a');
      mobileMenuLinks.forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenuButton.setAttribute('aria-expanded', 'false');
          mobileMenu.setAttribute('aria-hidden', 'true');
          mobileMenu.classList.add('hidden');
        });
      });
    }
  });
</script>

---
import { siteConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';

const { googleRating, googleReviewCount, googleUrl, replyTime, industries } =
  siteConfig.trustBar;

const industryFocus = industries.slice(0, 4).join(', ');
---

<section
  class="border-brand-primary border-b-2 bg-white px-4 sm:px-6 lg:px-8"
  aria-label="Vertrauenssignale"
>
  <div class="mx-auto grid max-w-7xl grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
    <a
      href={googleUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="border-brand-primary/25 group border-b py-5 sm:border-r lg:border-b-0"
    >
      <p
        class="text-brand-muted mb-2 text-xs font-semibold tracking-wide uppercase"
      >
        Bewertung
      </p>
      <div class="flex items-center gap-2">
        <div class="flex">
          {
            Array.from({ length: 5 }).map(() => (
              <Icon
                name="heroicons:star-solid"
                class="text-brand-accent h-4 w-4"
              />
            ))
          }
        </div>
        <span class="text-brand-primary text-sm font-bold">{googleRating}</span>
        <Icon
          name="heroicons:arrow-top-right-on-square"
          class="text-brand-muted group-hover:text-brand-primary h-3.5 w-3.5 transition-colors"
        />
      </div>
    </a>

    <div
      class="border-brand-primary/25 border-b py-5 sm:pl-6 lg:border-r lg:border-b-0"
    >
      <p
        class="text-brand-muted mb-2 text-xs font-semibold tracking-wide uppercase"
      >
        Google
      </p>
      <p class="text-brand-primary text-sm font-semibold">
        {googleReviewCount} Bewertungen auf Google
      </p>
    </div>

    <div
      class="border-brand-primary/25 border-b py-5 sm:border-r sm:pl-0 lg:border-b-0 lg:pl-6"
    >
      <p
        class="text-brand-muted mb-2 text-xs font-semibold tracking-wide uppercase"
      >
        Rückmeldung
      </p>
      <p class="text-brand-primary text-sm font-semibold">{replyTime}</p>
    </div>

    <div class="py-5 sm:pl-6">
      <p
        class="text-brand-muted mb-2 text-xs font-semibold tracking-wide uppercase"
      >
        Fokus
      </p>
      <p class="text-brand-primary text-sm font-semibold">
        {industryFocus}
      </p>
    </div>
  </div>
</section>

---
import { siteConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';
import { testimonialsData } from '../content/testimonials';
---

<section id="testimonials" class="relative bg-white px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="scroll-fade-up mx-auto mb-16 max-w-3xl text-center">
      <h2 class="text-brand-primary mb-4 text-4xl font-bold sm:text-5xl">
        {siteConfig.testimonials.title}
      </h2>
      <p class="text-brand-muted text-xl">
        {siteConfig.testimonials.subtitle}
      </p>
    </div>

    <div class="mb-12 grid grid-cols-1 gap-8 md:grid-cols-3">
      {
        testimonialsData.map((testimonial, index) => (
          <div
            class={`scroll-fade-up border-brand-accent bg-brand-bg rounded-xl border-l-4 p-8 shadow-sm stagger-${(index % 9) + 1}`}
          >
            <div class="mb-4 flex">
              {Array.from({ length: testimonial.rating }).map(() => (
                <Icon
                  name="heroicons:star-solid"
                  class="text-brand-accent h-5 w-5"
                />
              ))}
            </div>
            <p class="text-brand-muted mb-6 leading-relaxed">
              „{testimonial.quote}"
            </p>
            <div class="flex items-center">
              <div class="bg-brand-primary mr-4 flex h-12 w-12 items-center justify-center rounded-full font-semibold text-white">
                {testimonial.initials}
              </div>
              <div>
                <div class="text-brand-primary font-semibold">
                  {testimonial.author}
                </div>
                <div class="text-brand-secondary text-sm">
                  {testimonial.role}, {testimonial.company}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="scroll-fade-up text-center">
      <a
        href={siteConfig.testimonials.googleUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="border-brand-surface hover:border-brand-accent hover:text-brand-accent text-brand-muted inline-flex items-center gap-2 rounded-lg border-2 bg-white px-6 py-3 text-sm font-medium transition-colors"
      >
        <Icon name="heroicons:star-solid" class="text-brand-accent h-5 w-5" />
        {siteConfig.testimonials.googleLabel}
        <Icon name="heroicons:arrow-top-right-on-square" class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>

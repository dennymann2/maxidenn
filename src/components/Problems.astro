---
import { siteConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';

const { title, subtitle, items } = siteConfig.problems;
---

<section class="bg-brand-primary px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="scroll-fade-up mx-auto mb-16 max-w-3xl text-center">
      <h2 class="mb-4 text-4xl font-bold text-white sm:text-5xl">
        {title}
      </h2>
      <p class="text-xl text-white/60">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        items.map((item, index) => (
          <div
            class={`scroll-fade-up border-brand-accent/30 rounded-xl border-l-4 bg-white/5 p-8 stagger-${index + 1}`}
          >
            <div class="mb-4 flex items-start gap-3">
              <Icon
                name="heroicons:exclamation-triangle"
                class="text-brand-accent mt-0.5 h-5 w-5 flex-shrink-0"
              />
              <p class="font-semibold text-white">{item.problem}</p>
            </div>
            <p class="text-sm leading-relaxed text-white/50">
              {item.consequence}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

---
import { siteConfig } from '../config.ts';
import { Icon } from 'astro-icon/components';

const { title, subtitle, items } = siteConfig.problems;
---

<section class="bg-brand-primary px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mb-10 max-w-3xl">
      <h2 class="mb-4 text-3xl font-bold text-white sm:text-4xl">
        {title}
      </h2>
      <p class="text-lg text-white">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        items.map((item) => (
          <div class="border-brand-accent border-l-4 bg-white p-6">
            <div class="mb-4 flex items-start gap-3">
              <Icon
                name="heroicons:exclamation-triangle"
                class="text-brand-accent mt-0.5 h-5 w-5 flex-shrink-0"
              />
              <p class="text-brand-primary font-semibold">{item.problem}</p>
            </div>
            <p class="text-brand-primary text-sm leading-relaxed">
              {item.consequence}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
